{
  "name": "scaffold-day",
  "version": "0.2.0",
  "private": true,
  "description": "Scaffold your day with AI. AGPL-3.0-or-later.",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://scaffold.at/day",
  "repository": {
    "type": "git",
    "url": "https://github.com/scaffold-at/day.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:cli": "bun run packages/day-cli/src/index.ts",
    "smoke": "bun run scripts/bun-compat-smoke.ts",
    "validate:help": "bun run scripts/validate-help.ts",
    "bench:token": "bun run scripts/bench-token.ts",
    "gen:agents-md": "bun run scripts/gen-agents-md.ts",
    "check:agents-md": "bun run scripts/gen-agents-md.ts --check",
    "gen:cli-reference": "bun run scripts/gen-cli-reference.ts",
    "check:cli-reference": "bun run scripts/gen-cli-reference.ts --check",
    "test": "bun test",
    "test:unit": "bun test packages",
    "test:e2e": "bun test tests/e2e",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@modelcontextprotocol/sdk": "1.18.2",
    "@types/bun": "^1.1.13",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
